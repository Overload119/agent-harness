// node_modules/liquid/lib/liquid/tags/include.js
var require_include = __commonJS((exports, module) => {
  var Liquid = require_liquid();
  var Syntax = /((?:{{2}\s?)?[a-z0-9/\\_.-]+(?:\s?}{2})?)/i;
  var SyntaxHelp = "Syntax Error in 'include' - Valid syntax: include [templateName]";
  module.exports = class Include extends Liquid.Tag {
    constructor(template, tagName, markup) {
      super(template, tagName, markup);
      const match = Syntax.exec(markup);
      if (!match) {
        throw new Liquid.SyntaxError(SyntaxHelp);
      }
      this.filepath = match[1];
    }
    async subTemplate(context) {
      if (this.filepath.startsWith("{{") && this.filepath.endsWith("}}")) {
        this.filepath = await context.get(this.filepath);
      }
      const src = await this.template.engine.fileSystem.readTemplateFile(this.filepath);
      return this.template.engine.parse(src);
    }
    async render(context) {
      const subTemplate = await this.subTemplate(context);
      return subTemplate.render(context);
    }
  };
});

// node_modules/liquid/lib/liquid/tags/render.js
var require_render = __commonJS((exports, module) => {
  var Liquid = require_liquid();
  var IsStringReg = /^('|").*\1$/;
  var OptionsSyntax = /([a-zA-Z-_]+):\s([a-zA-Z0-9\d-_\s"']+)/g;
  var OperatorSyntax = /(?<keyword>with|for)\s(?<value>[a-zA-Z-_]+)\sas\s(?<key>[a-zA-Z0-9\d-_\s"']+)/;
  var Syntax = new RegExp(`^(?<filepath>('|")?[a-zA-Z-]+\\2)(?<variables>(?:\\s${OperatorSyntax.source}|(?:,\\s${OptionsSyntax.source})*))`);
  var SyntaxHelp = "Syntax Error in 'render' - Valid syntax: render [templateName]";
  module.exports = class Render extends Liquid.Tag {
    constructor(template, tagName, markup) {
      super(template, tagName, markup);
      const match = Syntax.exec(markup);
      if (!match) {
        throw new Liquid.SyntaxError(SyntaxHelp);
      }
      this.filepath = match.groups.filepath;
      this.variables = match.groups.variables.trim();
      if (match.groups.keyword) {
        this.keyword = match.groups.keyword;
        this.operatorKey = match.groups.key.trim();
        this.operatorValue = match.groups.value.trim();
      }
    }
    async serializeValue(value, context) {
      if (IsStringReg.test(value)) {
        return value.slice(1, value.length - 1);
      } else {
        return context.get(value);
      }
    }
    async parseVariables(context) {
      if (!this.variables)
        return {};
      if (this.keyword) {
        return {
          [this.operatorKey]: await this.serializeValue(this.operatorValue, context)
        };
      }
      const options = {};
      let optionsMatch;
      while (optionsMatch = OptionsSyntax.exec(this.variables)) {
        const [, key, value] = optionsMatch;
        options[key] = await this.serializeValue(value, context);
      }
      return options;
    }
    async subTemplate(context) {
      this.filepath = await this.serializeValue(this.filepath, context);
      const src = await this.template.engine.fileSystem.readTemplateFile(this.filepath);
      return this.template.engine.parse(src);
    }
    async renderAll(subTemplate, variables) {
      const renders = [];
      const value = variables[this.operatorKey];
      if (!value)
        return;
      const length = value.length;
      for (let index = 0;index < length; index++) {
        const item = value[index];
        const forloop = {
          length,
          index: index + 1,
          index0: index,
          rindex: length - index,
          rindex0: length - index - 1,
          first: index === 0,
          last: index === length - 1
        };
        const rendered = await subTemplate.render({ [this.operatorKey]: item, forloop });
        renders.push(rendered);
      }
      return renders.join("");
    }
    async render(context) {
      const subTemplate = await this.subTemplate(context);
      const variables = await this.parseVariables(context);
      if (this.keyword === "for") {
        return this.renderAll(subTemplate, variables);
      } else {
        return subTemplate.render(variables);
      }
    }
  };
});

// node_modules/liquid/lib/index.js
var require_lib = __commonJS((exports, module) => {
  var Liquid = require_liquid();
  var util = __require("util");
  function createCustomError(name, inherit = global.Error) {
    const error = function(message) {
      this.name = name;
      this.message = message;
      if (global.Error.captureStackTrace) {
        return global.Error.captureStackTrace(this, arguments.callee);
      }
    };
    util.inherits(error, inherit);
    return error;
  }
  Liquid.Error = createCustomError("Error");
  ["ArgumentError", "ContextError", "FilterNotFound", "FileSystemError", "StandardError", "StackLevelError", "SyntaxError"].forEach((className) => {
    Liquid[className] = createCustomError("Liquid." + className, Liquid.Error);
    return Liquid[className];
  });
  Liquid.Engine = require_engine();
  Liquid.Helpers = require_helpers();
  Liquid.Range = require_range();
  Liquid.Iterable = require_iterable();
  Liquid.Drop = require_drop();
  Liquid.Context = require_context();
  Liquid.Tag = require_tag();
  Liquid.Block = require_block();
  Liquid.Document = require_document();
  Liquid.Variable = require_variable();
  Liquid.Template = require_template();
  Liquid.StandardFilters = require_standard_filters();
  Liquid.Condition = require_condition();
  Liquid.ElseCondition = require_else_condition();
  Liquid.BlankFileSystem = require_blank_file_system();
  Liquid.LocalFileSystem = require_local_file_system();
  Liquid.Assign = require_assign();
  Liquid.Capture = require_capture();
  Liquid.Case = require_case();
  Liquid.Comment = require_comment();
  Liquid.Decrement = require_decrement();
  Liquid.For = require_for();
  Liquid.If = require_if();
  Liquid.Ifchanged = require_ifchanged();
  Liquid.Increment = require_increment();
  Liquid.Raw = require_raw();
  Liquid.Unless = require_unless();
  Liquid.Include = require_include();
  Liquid.Render = require_render();
  module.exports = Liquid;
});

