} = import__.default;

// src/harness/paths.ts
import os from "os";
import path from "path";
var HARNESS_DIR_NAME = ".agent-harness";
function homeHarnessRoot() {
  return path.join(os.homedir(), HARNESS_DIR_NAME);
}
function repoHarnessRoot(rootDir) {
